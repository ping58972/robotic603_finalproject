<launch>
  <arg name="start_camera" default="true"/>
  <arg name="camera_name" default="stingray_camera"/>
  <arg name="camera_device" default="/dev/video0"/>
  <arg name="image_width" default="640"/>
  <arg name="image_height" default="480"/>
  <arg name="pixel_format" default="yuyv"/>
  <arg name="camera_frame_id" default="camera_link"/>
  <arg name="camera_info_url" default=""/>
  <arg name="io_method" default="mmap"/>
  <arg name="framerate" default="30"/>
  <arg name="image_topic" default="/camera/image_raw"/>
  <arg name="camera_info_topic" default="/camera/camera_info"/>

  <arg name="start_lidar" default="true"/>
  <arg name="lidar_serial_port" default="/dev/ttyUSB0"/>
  <arg name="lidar_serial_baudrate" default="115200"/>
  <arg name="lidar_frame_id" default="laser"/>
  <arg name="lidar_inverted" default="false"/>
  <arg name="lidar_angle_compensate" default="true"/>
  <arg name="scan_topic" default="/scan"/>

  <group if="$(arg start_camera)">
    <node name="$(arg camera_name)" pkg="usb_cam" type="usb_cam_node" output="screen">
      <param name="video_device" type="string" value="$(arg camera_device)"/>
      <param name="image_width" type="int" value="$(arg image_width)"/>
      <param name="image_height" type="int" value="$(arg image_height)"/>
      <param name="pixel_format" type="string" value="$(arg pixel_format)"/>
      <param name="camera_frame_id" type="string" value="$(arg camera_frame_id)"/>
      <param name="camera_info_url" type="string" value="$(arg camera_info_url)"/>
      <param name="io_method" type="string" value="$(arg io_method)"/>
      <param name="framerate" type="int" value="$(arg framerate)"/>
      <remap from="image_raw" to="$(arg image_topic)"/>
      <remap from="camera_info" to="$(arg camera_info_topic)"/>
    </node>
  </group>

  <group if="$(arg start_lidar)">
    <node name="rplidarNode" pkg="rplidar_ros" type="rplidarNode" output="screen">
      <param name="serial_port" type="string" value="$(arg lidar_serial_port)"/>
      <param name="serial_baudrate" type="int" value="$(arg lidar_serial_baudrate)"/>
      <param name="frame_id" type="string" value="$(arg lidar_frame_id)"/>
      <param name="inverted" type="bool" value="$(arg lidar_inverted)"/>
      <param name="angle_compensate" type="bool" value="$(arg lidar_angle_compensate)"/>
      <remap from="scan" to="$(arg scan_topic)"/>
    </node>
  </group>
</launch>
